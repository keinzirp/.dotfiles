{
  "allowedTools": [
    "Read",
    "Glob",
    "Grep",
    "Bash(ansible-doc:*)",
    "Bash(command -v:*)",
    "Bash(fd:*)",
    "Bash(find:*)",
    "Bash(gh pr diff:*)",
    "Bash(gh pr list:*)",
    "Bash(gh pr review-comment list:*)",
    "Bash(gh pr view:*)",
    "Bash(grep:*)",
    "Bash(hadolint:*)",
    "Bash(helm template:*)",
    "Bash(ls:*)",
    "Bash(rg:*)",
    "Bash(yamllint:*)",
    "Bash(find:*)",
    "Bash(rodney:*)"
  ],
  "effortLevel": "medium",
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "atuin hook claude-code",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PostToolUseFailure": [
      {
        "hooks": [
          {
            "command": "atuin hook claude-code",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "atuin hook claude-code",
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ]
  },
  "model": "opus",
  "permissions": {
    "defaultMode": "default"
  },
  "statusLine": {
    "command": "bash /Users/keinzirp/.claude/statusline.sh",
    "type": "command"
  }
}