{
  "permissions": {
    "defaultMode": "default"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "atuin hook claude-code"
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "atuin hook claude-code"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "atuin hook claude-code"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash /Users/keinzirp/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "jj-workflow@jj-workflow": true,
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "jj-workflow": {
      "source": {
        "source": "github",
        "repo": "kalupa/jj-workflow"
      }
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "effortLevel": "medium",
  "allowedTools": [
    "Read",
    "Glob",
    "Grep",
    "Bash(ansible-doc:*)",
    "Bash(command -v:*)",
    "Bash(fd:*)",
    "Bash(find:*)",
    "Bash(gh pr diff:*)",
    "Bash(gh pr list:*)",
    "Bash(gh pr review-comment list:*)",
    "Bash(gh pr view:*)",
    "Bash(grep:*)",
    "Bash(hadolint:*)",
    "Bash(helm template:*)",
    "Bash(ls:*)",
    "Bash(rg:*)",
    "Bash(yamllint:*)",
    "Bash(find:*)",
    "Bash(rodney:*)",
    "Bash(jj:*)"
  ]
}
